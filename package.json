{
  "name": "magic-novel",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:tool-agent": "node scripts/run-tool-agent-tests.mjs",
    "test:tool-schema-inventory": "cargo test --manifest-path src-tauri/Cargo.toml agent_tools::registry::tests::test_tool_schema_inventory_matches_snapshot -- --exact",
    "test:tool-provider-smoke": "cargo run --manifest-path src-tauri/Cargo.toml --bin tool_provider_smoke",
    "tool-schema-inventory:update": "cargo run --manifest-path src-tauri/Cargo.toml --bin tool_schema_inventory -- --output schemas/agent-tool-schema-inventory.json",
    "test:tool-agent-scenarios": "node scripts/simulate-tool-agent-scenarios.mjs",
    "test:tool-agent-stability": "node scripts/stability-tool-agent.mjs",
    "test:agent-chat": "node scripts/validate-agent-chat.mjs",
    "test:session-regression": "node scripts/test-session-regression.mjs",
    "test:dev-a-runtime-state-machine": "node scripts/test-dev-a-runtime-state-machine.mjs",
    "test:agent-prompt-memory-model": "node scripts/test-agent-prompt-memory-model.mjs",
    "test:dev-c-observability": "node scripts/test-dev-c-observability.mjs",
    "test:session-canary-rollout": "node scripts/test-session-canary-rollout.mjs",
    "test:session-rollback-drill": "node scripts/test-session-rollback-drill.mjs",
    "test:agent-utility-tools": "node scripts/test-agent-utility-tools.mjs",
    "canary:session-v2": "node scripts/session-v2-canary.mjs",
    "canary:session-v2:rollout": "node scripts/session-v2-canary-rollout.mjs",
    "rollback:session-v2": "node scripts/session-v2-rollback.mjs",
    "rollback:session-v2:drill": "node scripts/session-v2-rollback-drill.mjs",
    "check:governance": "node scripts/check-governance.mjs",
    "check:governance:strict": "node scripts/check-governance.mjs --strict",
    "check:governance:update-baseline": "node scripts/check-governance.mjs --update-baseline",
    "dod:phase6": "node scripts/phase6-dod-check.mjs",
    "dod:phase6:strict": "node scripts/phase6-dod-check.mjs --strict"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
