{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "magic-asset.node.schema.json",
  "title": "Magic Asset Node",
  "type": "object",
  "additionalProperties": false,
  "required": ["node_id", "title", "level", "content", "children"],
  "properties": {
    "node_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string" },
    "level": { "type": "integer", "minimum": 0 },
    "content": { "type": "string" },
    "children": {
      "type": "array",
      "items": { "$ref": "magic-asset.node.schema.json" }
    },
    "tags": {
      "type": ["array", "null"],
      "items": { "type": "string" }
    }
  }
}
