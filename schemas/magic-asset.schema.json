{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "magic-asset.schema.json",
  "title": "Magic Asset",
  "oneOf": [
    {
      "allOf": [
        { "$ref": "magic-asset.base.schema.json" },
        { "properties": { "kind": { "const": "worldview" } } }
      ]
    },
    {
      "allOf": [
        { "$ref": "magic-asset.base.schema.json" },
        { "properties": { "kind": { "const": "outline" } } }
      ]
    },
    {
      "allOf": [
        { "$ref": "magic-asset.base.schema.json" },
        { "properties": { "kind": { "const": "character" } } }
      ]
    },
    {
      "allOf": [
        { "$ref": "magic-asset.base.schema.json" },
        { "properties": { "kind": { "const": "lore" } } }
      ]
    },
    {
      "allOf": [
        { "$ref": "magic-asset.base.schema.json" },
        { "properties": { "kind": { "const": "prompt" } } }
      ]
    }
  ]
}
